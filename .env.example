# Wazi Wonderland - Environment Configuration Template
# Copy this file to '.env.local' and populate with your own keys to swap from simulation to production mode.

# Supabase Credentials (Required to go Live)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-public-anon-key

# Administrative keys (Keep secure, only needed for local CLI operations/migrations)
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-private-service-role-key
